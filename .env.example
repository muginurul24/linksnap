# LinkSnap — Environment Variables
# Copy this file to .env and fill in actual values

# Database (Neon.tech)
DATABASE_URL=postgresql://...

# Auth (NextAuth.js v5)
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Redis (Upstash)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Resend (Email)
RESEND_API_KEY=

# Midtrans (Payment)
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=

# Stripe (Payment)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_IS_TEST_MODE=true

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
CRON_SECRET=

# Geo IP (MaxMind)
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=./src/database/geolite/city.mmdb

# Analytics
IP_HASH_SALT=

# USD to IDR rate (manual override, or auto-fetch)
USD_IDR_RATE=16000
