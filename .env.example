# LinkSnap environment template
# Copy to .env for local development. Do not commit .env, .env.local, or .env.production.
# Production domain: https://www.justqiu.cloud

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
# Public browser-facing base URL. In production this must be https://www.justqiu.cloud.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public API base URL used by clients and docs.
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Server-side canonical app URL used for payment redirects and operational checks.
# In production this should match NEXT_PUBLIC_APP_URL.
APP_URL=http://localhost:3000

# Auth.js / NextAuth.js canonical URL.
# Auth.js v5 reads AUTH_URL; NEXTAUTH_URL is kept as a compatibility alias for tooling.
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Neon PostgreSQL connection string. Use pooled Neon connection URL in production.
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# 32+ byte random secret. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client credentials.
# Production callback URL: https://www.justqiu.cloud/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Upstash Redis REST URL and token. Used for rate limits, sessions, queues, and cache.
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
# Resend API key for transactional auth and payment emails.
RESEND_API_KEY=

# Verified sender identity. Example: LinkSnap <noreply@justqiu.cloud>
RESEND_FROM_EMAIL="LinkSnap <noreply@justqiu.cloud>"

# Local/E2E only. Do not set AUTH_EMAIL_DELIVERY=file in production.
# AUTH_EMAIL_DELIVERY=file
# AUTH_EMAIL_FILE=.e2e/auth-emails.jsonl
# PAYMENT_EMAIL_DELIVERY=file
# PAYMENT_EMAIL_FILE=.e2e/payment-emails.jsonl

# -----------------------------------------------------------------------------
# PayGate
# -----------------------------------------------------------------------------
# LinkSnap PayGate middleware base URL.
PAYGATE_API_BASE_URL=https://paygate.digixsolution.net

# Store token from PayGate dashboard. Never expose this to browsers.
PAYGATE_STORE_API_TOKEN=

# HMAC webhook secret from PayGate dashboard.
PAYGATE_WEBHOOK_SECRET=

# Production webhook URL to configure in PayGate:
# https://www.justqiu.cloud/api/v1/payments/webhook

# -----------------------------------------------------------------------------
# Cron
# -----------------------------------------------------------------------------
# Shared secret for Vercel Cron endpoints.
# Used by:
# - /api/v1/analytics/click-queue/process
# - /api/v1/payments/subscriptions/renew
CRON_SECRET=

# -----------------------------------------------------------------------------
# Geo IP
# -----------------------------------------------------------------------------
# Optional MaxMind account key if downloading databases manually.
MAXMIND_LICENSE_KEY=

# Local path to GeoLite2 City mmdb. For local dev this repo expects:
# /home/mugiew/projects/linksnap/src/database/geolite/city.mmdb
MAXMIND_DB_PATH=./src/database/geolite/city.mmdb

# -----------------------------------------------------------------------------
# Analytics and pricing
# -----------------------------------------------------------------------------
# Secret salt for irreversible IP hashing before analytics persistence.
IP_HASH_SALT=

# USD to IDR conversion override used by pricing when provider rates are unavailable.
USD_IDR_RATE=16000

# -----------------------------------------------------------------------------
# E2E and smoke testing only
# -----------------------------------------------------------------------------
# Base URL and port used by Playwright helpers.
# E2E_BASE_URL=http://127.0.0.1:3100
# E2E_PORT=3100

# Optional production smoke cookie for authenticated dashboard checks.
# PRODUCTION_SMOKE_COOKIE=
# PRODUCTION_SMOKE_ADMIN_USER_ID=
# PRODUCTION_SMOKE_ADMIN_PLAN=BUSINESS
# PRODUCTION_SMOKE_RUN_ADMIN_MUTATION=false
