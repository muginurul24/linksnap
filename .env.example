# LinkSnap — Environment Variables
# Copy this file to .env and fill in actual values

# Database (Neon.tech)
DATABASE_URL=postgresql://...

# Auth (NextAuth.js v5)
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Redis (Upstash)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Resend (Email)
RESEND_API_KEY=

# Midtrans (Payment)
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# Geo IP (MaxMind)
MAXMIND_LICENSE_KEY=
MAXMIND_DB_PATH=./src/database/geolite/city.mmdb

# Analytics
IP_HASH_SALT=

# USD to IDR rate (manual override, or auto-fetch)
USD_IDR_RATE=16000
